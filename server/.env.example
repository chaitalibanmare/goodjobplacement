# Copy to .env and fill in your actual values

# Supabase credentials (get from supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key-here

# JWT secret for signing your own auth tokens
JWT_SECRET=replace_with_a_long_strong_secret

PORT=5000
